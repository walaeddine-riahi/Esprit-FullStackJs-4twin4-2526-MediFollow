// MediFollow - Post-Hospitalization Remote Monitoring Platform
// Prisma Schema for MongoDB
// Generated: March 2, 2026

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ============================================
// USER MANAGEMENT
// ============================================

model User {
  id                      String    @id @default(auto()) @map("_id") @db.ObjectId
  email                   String    @unique
  passwordHash            String
  firstName               String
  lastName                String
  role                    Role      @default(PATIENT)
  phoneNumber             String?
  blockchainAddress       String?   // Aptos wallet address (public) for blockchain access control
  blockchainPrivateKey    String?   // Aptos wallet private key (encrypted at rest)
  isActive                Boolean   @default(true)
  mustChangePassword      Boolean   @default(false)  // Force password change on first login
  lastLogin               DateTime?
  resetPasswordToken      String?   // Token for password reset
  resetPasswordExpires    DateTime? // Expiration date for reset token
  faceDescriptor          Json?     // 128-dim float array for facial recognition login
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  // Relations
  patient       Patient?
  doctorProfile DoctorProfile?
  nurseProfile  NurseProfile?
  auditLogs     AuditLog[]
  alertsCreated Alert[]    @relation("AlertCreatedBy")
  alertsAcknowledged Alert[] @relation("AlertAcknowledgedBy")
  alertsResolved Alert[]    @relation("AlertResolvedBy")
  vitalRecordReviews VitalRecord[] @relation("VitalRecordReviews")  // Vitals reviewed by this doctor
  doctorNotes   DoctorNote[]
  situationReportsCreated SituationReport[] @relation("SituationReportCreatedBy")
  // TODO_MERGE #2: Added from branche_patient - questionnaire system
  questionnaireTemplates QuestionnaireTemplate[] @relation("QuestionnaireTemplates")  // Questionnaires created by this doctor
  analysisRequests AnalysisRequest[] @relation("DoctorAnalysisRequests")  // Analysis requests created by this doctor
  sessions      Session[]

  @@map("users")
}

enum Role {
  PATIENT
  DOCTOR
  NURSE
  ADMIN
  AUDITOR
  COORDINATOR
}

// ============================================
// PATIENT MANAGEMENT
// ============================================

model Patient {
  id                    String    @id @default(auto()) @map("_id") @db.ObjectId
  userId                String    @unique @db.ObjectId
  medicalRecordNumber   String    @unique
  dateOfBirth           DateTime
  gender                Gender
  bloodType             BloodType?
  address               Address?
  emergencyContact      EmergencyContact?
  profileImage          String?   // Base64 or URL to profile image
  bio                   String?   // Patient personal bio
  dischargeDate         DateTime?
  diagnosis             String?
  medications           Medication[]
  vitalThresholds       VitalThresholds?
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  vitalRecords          VitalRecord[]
  symptoms              Symptom[]
  alerts                Alert[]
  questionnaires        Questionnaire[]
  medicalDocuments      MedicalDocument[]
  medicalAnalyses       MedicalAnalysis[]
  doctorNotes           DoctorNote[]
  situationReports      SituationReport[]
  patientReminders      PatientReminder[]  // Reminders sent by nurses
  // TODO_MERGE #3: Added from branche_patient - questionnaire system
  questionnaireAssignments QuestionnaireAssignment[] @relation("QuestionnaireAssignments")  // Questionnaires assigned to this patient
  analysisRequests      AnalysisRequest[] @relation("PatientAnalysisRequests")  // Analysis requests for this patient

  @@map("patients")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum BloodType {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
}

// ============================================
// MEDICAL SPECIALTIES ENUM (TODO_MERGE #1)
// ============================================

enum MedicalSpecialty {
  CARDIOLOGY
  NEUROLOGY
  ORTHOPEDICS
  PULMONOLOGY
  GASTROENTEROLOGY
  ENDOCRINOLOGY
  RHEUMATOLOGY
  NEPHROLOGY
  HEMATOLOGY
  ONCOLOGY
  PSYCHIATRY
  DERMATOLOGY
  ENT
  OPHTHALMOLOGY
  GENERAL_MEDICINE
  OTHER
}

// ============================================
// DOCTOR PROFILE
// ============================================

model DoctorProfile {
  id              String            @id @default(auto()) @map("_id") @db.ObjectId
  userId          String            @unique @db.ObjectId
  // TODO_MERGE #1: Changed from String? to MedicalSpecialty? enum for type safety
  specialty       MedicalSpecialty?
  bio             String?
  phone           String?
  location        String?
  profileImage    String?      // URL to profile image (Azure Blob Storage)
  experiences     Experience[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("doctor_profiles")
}

// ============================================
// NURSE PROFILE
// ============================================

model NurseProfile {
  id              String            @id @default(auto()) @map("_id") @db.ObjectId
  userId          String            @unique @db.ObjectId
  licenseNumber   String            @unique
  bio             String?
  phone           String?
  location        String?
  profileImage    String?      // URL to profile image
  specialization  String?      // e.g., ICU, Emergency, Cardiology
  certifications  String[]     // Array of certification names
  assignedPatients String[]    @db.ObjectId  // Patient IDs assigned to this nurse
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  patientReminders PatientReminder[]

  @@map("nurse_profiles")
}

type Experience {
  title         String
  institution   String
  startDate     DateTime
  endDate       DateTime?
  isCurrent     Boolean      @default(false)
  description   String?
}

// ============================================
// EMBEDDED TYPES FOR PATIENT
// ============================================

type Address {
  street      String
  city        String
  state       String
  postalCode  String
  country     String
}

type EmergencyContact {
  name         String
  relationship String
  phoneNumber  String
  email        String?
}

type Medication {
  name        String
  dosage      String
  frequency   String
  startDate   DateTime
  endDate     DateTime?
  notes       String?
}

type VitalThresholds {
  systolicBP          VitalRange
  diastolicBP         VitalRange
  heartRate           VitalRange
  temperature         VitalRange
  oxygenSaturation    VitalRange
  weight              VitalRange?
}

type VitalRange {
  min Float
  max Float
}

// ============================================
// VITAL RECORDS
// ============================================

model VitalRecord {
  id                  String          @id @default(auto()) @map("_id") @db.ObjectId
  patientId           String          @db.ObjectId
  
  // Vital measurements
  systolicBP          Float?
  diastolicBP         Float?
  heartRate           Float?
  temperature         Float?
  oxygenSaturation    Float?
  weight              Float?
  
  // Additional data
  symptoms            Json?           // { symptomType: severity, ... }
  notes               String?
  triggeredRules      Json?           // Array of rules that triggered alerts
  
  // Status & Classification
  status              VitalStatus     @default(NORMAL)  // NORMAL | A_VERIFIER | CRITIQUE
  
  // Medical review by doctor
  reviewStatus        ReviewStatus    @default(PENDING) // PENDING | REVIEWED
  reviewedById        String?         @db.ObjectId
  reviewedAt          DateTime?
  reviewNotes         String?
  
  // Metadata
  recordedAt          DateTime        @default(now())
  blockchainTxHash    String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime?       @updatedAt

  // Relations
  patient             Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  reviewedBy          User?           @relation("VitalRecordReviews", fields: [reviewedById], references: [id])
  blockchainProof     BlockchainProof?
  alerts              Alert[]         // Alerts triggered by this vital

  @@index([patientId])
  @@index([recordedAt])
  @@index([status])
  @@index([reviewStatus])
  @@map("vital_records")
}

enum VitalStatus {
  NORMAL              // Valeur normale
  A_VERIFIER          // Valeur anormale nécessitant vérification
  CRITIQUE            // Valeur critique nécessitant intervention urgente
}

enum ReviewStatus {
  PENDING             // En attente révision médecin
  REVIEWED            // Révisé par médecin
}

// ============================================
// SYMPTOMS
// ============================================

model Symptom {
  id           String         @id @default(auto()) @map("_id") @db.ObjectId
  patientId    String         @db.ObjectId
  symptomType  String
  severity     Severity
  description  String
  occurredAt   DateTime       @default(now())
  createdAt    DateTime       @default(now())

  // Relations
  patient      Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([occurredAt])
  @@map("symptoms")
}

enum Severity {
  MILD
  MODERATE
  SEVERE
}

// ============================================
// ALERTS
// ============================================

model Alert {
  id                  String          @id @default(auto()) @map("_id") @db.ObjectId
  patientId           String          @db.ObjectId
  
  // Alert source (what triggered it)
  vitalRecordId       String?         @db.ObjectId      // Lien vers VitalRecord si vitals triggered
  triggeredById       String?         @db.ObjectId      // User who triggered/created alert
  
  // Alert type & severity
  alertType           AlertType
  severity            AlertSeverity
  message             String
  data                Json?           // Extra data about alert
  
  // Status workflow: OPEN → ACKNOWLEDGED → RESOLVED → CLOSED
  status              AlertStatus     @default(OPEN)
  
  // Acknowledgment
  acknowledgedById    String?         @db.ObjectId
  acknowledgedAt      DateTime?
  
  // Resolution
  resolvedById        String?         @db.ObjectId
  resolvedAt          DateTime?
  resolution          String?         // Notes on how alert was resolved
  
  // Metadata
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  // Relations
  patient             Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  vitalRecord         VitalRecord?    @relation(fields: [vitalRecordId], references: [id], onDelete: SetNull)
  triggeredBy         User?           @relation("AlertCreatedBy", fields: [triggeredById], references: [id])
  acknowledgedBy      User?           @relation("AlertAcknowledgedBy", fields: [acknowledgedById], references: [id])
  resolvedBy          User?           @relation("AlertResolvedBy", fields: [resolvedById], references: [id])
  auditLogs           AuditLog[]

  @@index([patientId])
  @@index([vitalRecordId])
  @@index([status])
  @@index([severity])
  @@index([createdAt])
  @@map("alerts")
}

enum AlertType {
  VITAL
  SYMPTOM
  MEDICATION
  SYSTEM
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  CLOSED
}

// ============================================
// PATIENT REMINDERS (Nurse-sent)
// ============================================

model PatientReminder {
  id              String            @id @default(auto()) @map("_id") @db.ObjectId
  patientId       String            @db.ObjectId
  nurseId         String            @db.ObjectId
  title           String
  message         String
  reminderType    ReminderType      // MEDICATION, APPOINTMENT, VITAL, QUESTIONNAIRE, etc.
  scheduledFor    DateTime          // When to send/show the reminder
  isSent          Boolean           @default(false)
  sentAt          DateTime?
  isRead          Boolean           @default(false)
  readAt          DateTime?
  priority        ReminderPriority  @default(NORMAL)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relations
  patient         Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  nurse           NurseProfile      @relation(fields: [nurseId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([nurseId])
  @@index([scheduledFor])
  @@index([isSent])
  @@map("patient_reminders")
}

enum ReminderType {
  MEDICATION
  APPOINTMENT
  VITAL_CHECK
  QUESTIONNAIRE
  FOLLOW_UP
  GENERAL
}

enum ReminderPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// ============================================
// SERVICES
// ============================================

model Service {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  serviceName       String   @unique
  description       String?
  consultationFee   Float?
  averageDuration   Int?     // in minutes
  isActive          Boolean  @default(true)
  specializations   String[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("services")
}

// ============================================
// QUESTIONNAIRES
// ============================================

model Questionnaire {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  patientId         String   @db.ObjectId
  questionnaireType String
  responses         Json
  overallScore      Float?
  completedAt       DateTime @default(now())
  createdAt         DateTime @default(now())

  // Relations
  patient           Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([completedAt])
  @@map("questionnaires")
}

// ============================================
// MEDICAL DOCUMENTS
// ============================================

model MedicalDocument {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  patientId       String         @db.ObjectId
  fileName        String
  originalName    String
  fileType        String
  fileSize        Int            // in bytes
  category        DocumentCategory
  description     String?
  azureBlobUrl    String
  azureContainerName String
  azureBlobName   String
  uploadedAt      DateTime       @default(now())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  patient         Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([uploadedAt])
  @@index([category])
  @@map("medical_documents")
}

enum DocumentCategory {
  ANALYSIS
  IMAGING
  PRESCRIPTION
  REPORT
  DISCHARGE_SUMMARY
  CONSULTATION
  OTHER
}

// ============================================
// MEDICAL ANALYSES
// ============================================

model MedicalAnalysis {
  id                String           @id @default(auto()) @map("_id") @db.ObjectId
  patientId         String           @db.ObjectId
  analysisType      AnalysisType
  testName          String           // Ex: "Numération Formule Sanguine", "Radiographie thorax"
  results           Json?            // Structured results (values, units, reference ranges)
  resultSummary     String?          // Text summary of results
  analysisDate      DateTime         @default(now())
  laboratory        String?          // Name of lab or medical center
  doctorNotes       String?
  status            AnalysisStatus   @default(PENDING)
  isAbnormal        Boolean          @default(false)
  documentIds       String[]         @db.ObjectId // Links to MedicalDocument for PDFs/images
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  // Relations
  patient           Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([analysisDate])
  @@index([analysisType])
  @@index([status])
  @@map("medical_analyses")
}

enum AnalysisType {
  BLOOD_TEST
  URINE_TEST
  IMAGING_XRAY
  IMAGING_CT_SCAN
  IMAGING_MRI
  IMAGING_ULTRASOUND
  IMAGING_PET_SCAN
  ECG
  ECHOCARDIOGRAPHY
  SPIROMETRY
  BIOPSY
  CULTURE
  OTHER
}

enum AnalysisStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ============================================
// AUDIT ACTIONS
// ============================================

enum AuditAction {
  // Authentication
  LOGIN
  LOGOUT
  PASSWORD_RESET
  
  // User Management
  CREATE_USER
  UPDATE_USER
  DELETE_USER
  CHANGE_ROLE
  
  // Patient Management
  CREATE_PATIENT
  UPDATE_PATIENT
  DELETE_PATIENT
  VIEW_PATIENT
  
  // Medical Records
  CREATE_VITAL_SIGN
  UPDATE_VITAL_SIGN
  DELETE_VITAL_SIGN
  CREATE_MEDICAL_ANALYSIS
  UPDATE_MEDICAL_ANALYSIS
  DELETE_MEDICAL_ANALYSIS
  
  // Alerts
  CREATE_ALERT
  UPDATE_ALERT
  ACKNOWLEDGE_ALERT
  RESOLVE_ALERT
  DELETE_ALERT
  
  // Questionnaires
  CREATE_QUESTIONNAIRE
  UPDATE_QUESTIONNAIRE
  DELETE_QUESTIONNAIRE
  SUBMIT_QUESTIONNAIRE
  
  // Documents
  UPLOAD_DOCUMENT
  UPDATE_DOCUMENT
  DELETE_DOCUMENT
  DOWNLOAD_DOCUMENT
  
  // Access Control
  GRANT_ACCESS
  REVOKE_ACCESS
  
  // System
  EXPORT_DATA
  IMPORT_DATA
  SYSTEM_CONFIG
}

// ============================================
// AUDIT LOGS
// ============================================

model AuditLog {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  userId            String   @db.ObjectId
  action            String
  entityType        String
  entityId          String?  @db.ObjectId
  changes           Json?
  ipAddress         String?
  userAgent         String?
  blockchainTxHash  String?
  timestamp         DateTime @default(now())

  // Relations
  user              User     @relation(fields: [userId], references: [id])
  alert             Alert?   @relation(fields: [entityId], references: [id])
  blockchainProof   BlockchainProof?

  @@index([userId])
  @@index([entityType])
  @@index([timestamp])
  @@map("audit_logs")
}

// ============================================
// BLOCKCHAIN PROOF
// ============================================

model BlockchainProof {
  id                String       @id @default(auto()) @map("_id") @db.ObjectId
  dataHash          String
  txHash            String       @unique
  blockchainNetwork String       @default("aptos-testnet")
  blockNumber       Int?
  timestamp         DateTime     @default(now())
  status            BlockchainStatus @default(PENDING)
  
  // Relations (one-to-one)
  vitalRecordId     String?      @unique @db.ObjectId
  vitalRecord       VitalRecord? @relation(fields: [vitalRecordId], references: [id])
  
  auditLogId        String?      @unique @db.ObjectId
  auditLog          AuditLog?    @relation(fields: [auditLogId], references: [id])

  @@index([timestamp])
  @@map("blockchain_proofs")
}

enum BlockchainStatus {
  PENDING
  CONFIRMED
  FAILED
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id            String             @id @default(auto()) @map("_id") @db.ObjectId
  recipientId   String             @db.ObjectId
  type          NotificationType
  title         String
  message       String
  data          Json?
  isRead        Boolean            @default(false)
  readAt        DateTime?
  sentVia       NotificationChannel[]
  createdAt     DateTime           @default(now())

  @@index([recipientId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

enum NotificationType {
  ALERT
  REMINDER
  SYSTEM
  MESSAGE
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  PUSH
}

// ============================================
// SESSIONS (for JWT refresh tokens)
// ============================================

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  ipAddress    String?
  userAgent    String?

  // Relations
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// ============================================
// MEDICAL FORMS (Doctor-defined checkup forms)
// ============================================

model MedicalForm {
  id          String             @id @default(auto()) @map("_id") @db.ObjectId
  doctorId    String             @db.ObjectId
  title       String
  description String?
  category    String?            // e.g. "Cardiologie", "Diabète", "Suivi post-op"
  fields      MedicalFormField[]
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  // Relations
  checkups    PatientCheckup[]

  @@index([doctorId])
  @@index([isActive])
  @@map("medical_forms")
}

type MedicalFormField {
  id           String   // client-generated UUID
  label        String
  fieldType    String   // "text" | "number" | "textarea" | "select" | "checkbox" | "date"
  required     Boolean  @default(false)
  placeholder  String?
  options      String[] // for "select" type
  unit         String?  // for "number" e.g. "kg", "bpm"
  order        Int      @default(0)
}

// ============================================
// PATIENT CHECKUPS (form submissions)
// ============================================

model PatientCheckup {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  formId     String   @db.ObjectId
  patientId  String   @db.ObjectId
  doctorId   String   @db.ObjectId
  answers    Json     // { fieldId: value, ... }
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  form       MedicalForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
  @@index([patientId])
  @@index([doctorId])
  @@index([createdAt])
  @@map("patient_checkups")
}

// ============================================
// ACCESS GRANTS (Patient → Doctor blockchain permissions)
// ============================================

model AccessGrant {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  patientId       String    @db.ObjectId  // User.id of patient
  doctorId        String    @db.ObjectId  // User.id of doctor
  durationDays    Int       @default(365)
  grantedAt       DateTime  @default(now())
  expiresAt       DateTime?
  revokedAt       DateTime?
  isActive        Boolean   @default(true)
  txHashGrant     String?   // Blockchain tx hash for grant
  txHashRevoke    String?   // Blockchain tx hash for revoke

  @@unique([patientId, doctorId])
  @@index([patientId])
  @@index([doctorId])
  @@index([isActive])
  @@map("access_grants")
}

// ============================================
// DOCTOR NOTES (Medical notes by doctor for patient)
// ============================================

model DoctorNote {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  patientId String   @db.ObjectId
  doctorId  String   @db.ObjectId
  note      String   // Medical note content
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor    User     @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([doctorId])
  @@index([createdAt])
  @@map("doctor_notes")
}

// ============================================
// SITUATION REPORTS (AI-assisted clinical reports)
// ============================================

model SituationReport {
  id              String                @id @default(auto()) @map("_id") @db.ObjectId
  patientId       String                @db.ObjectId
  doctorId        String                @db.ObjectId
  title           String                // Report title
  content         String                // Main report content
  context         Json?                 // Clinical context: vitals, symptoms, etc.
  aiSummary       String?               // AI-generated summary
  status          SituationReportStatus @default(DRAFT)
  version         Int                   @default(1)
  isPublished     Boolean               @default(false)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  publishedAt     DateTime?

  // Relations
  patient         Patient               @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor          User                  @relation("SituationReportCreatedBy", fields: [doctorId], references: [id], onDelete: Cascade)
  versions        SituationReportVersion[]

  @@index([patientId])
  @@index([doctorId])
  @@index([status])
  @@index([createdAt])
  @@map("situation_reports")
}

model SituationReportVersion {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  reportId        String    @db.ObjectId
  versionNumber   Int
  content         String
  changeSummary   String?   // What changed in this version
  createdAt       DateTime  @default(now())

  // Relations
  report          SituationReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([versionNumber])
  @@map("situation_report_versions")
}

enum SituationReportStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  ARCHIVED
}

// ============================================
// QUESTIONNAIRE SYSTEM (TODO_MERGE #4-7)
// ============================================

enum QuestionType {
  TEXT
  TEXTAREA
  NUMBER
  RATING
  MULTIPLE_CHOICE
  CHECKBOX
  DATE
  TIME
  YESNO
}

model QuestionnaireTemplate {
  id                String          @id @default(auto()) @map("_id") @db.ObjectId
  doctorId          String          @db.ObjectId
  title             String
  description       String?
  specialty         MedicalSpecialty
  questions         QuestionnaireQuestion[]
  isAiGenerated     Boolean         @default(false)
  aiPrompt          String?         // The prompt used to generate questions via AI
  isPublished       Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  doctor            User            @relation("QuestionnaireTemplates", fields: [doctorId], references: [id], onDelete: Cascade)
  assignments       QuestionnaireAssignment[]

  @@index([doctorId])
  @@index([specialty])
  @@map("questionnaire_templates")
}

model QuestionnaireQuestion {
  id                String          @id @default(auto()) @map("_id") @db.ObjectId
  templateId        String          @db.ObjectId
  questionNumber    Int
  questionText      String
  questionType      QuestionType
  helpText          String?         // Additional guidance for patient
  
  // Options for multiple choice, checkbox, etc.
  options           Json?           // Array of {value, label}
  
  // Validation
  isRequired        Boolean         @default(true)
  minLength         Int?
  maxLength         Int?
  minValue          Float?
  maxValue          Float?
  
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  template          QuestionnaireTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  responses         QuestionnaireResponse[]

  @@index([templateId])
  @@map("questionnaire_questions")
}

enum AssignmentStatus {
  PENDING           // Not yet started
  IN_PROGRESS       // Patient started but not completed
  COMPLETED         // Patient completed
  EXPIRED           // Due date passed without completion
}

model QuestionnaireAssignment {
  id                String          @id @default(auto()) @map("_id") @db.ObjectId
  templateId        String          @db.ObjectId
  patientId         String          @db.ObjectId
  assignedAt        DateTime        @default(now())
  dueDate           DateTime?       // Deadline for patient to complete
  
  status            AssignmentStatus @default(PENDING)
  completedAt       DateTime?
  
  // Score if applicable
  score             Float?
  scoreOutOf        Float?          // Total possible score
  
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  template          QuestionnaireTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  patient           Patient         @relation("QuestionnaireAssignments", fields: [patientId], references: [id], onDelete: Cascade)
  responses         QuestionnaireResponse[]

  @@index([patientId])
  @@index([status])
  @@map("questionnaire_assignments")
}

model QuestionnaireResponse {
  id                String          @id @default(auto()) @map("_id") @db.ObjectId
  assignmentId      String          @db.ObjectId
  questionId        String          @db.ObjectId
  
  // Patient's answer
  responseText      String?
  responseNumber    Float?
  responseJson      Json?           // For complex responses (multiple selections, etc.)
  
  answeredAt        DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  assignment        QuestionnaireAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  question          QuestionnaireQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([assignmentId])
  @@index([questionId])
  @@map("questionnaire_responses")
}

// ============================================
// ANALYSIS REQUESTS (Doctor assigns to patient)
// ============================================

enum AnalysisRequestStatus {
  PENDING           // Not yet started by patient
  IN_PROGRESS       // Patient started
  SUBMITTED         // Patient submitted results
  APPROVED          // Doctor reviewed and approved
  REJECTED          // Doctor rejected, needs resubmission
  COMPLETED         // Fully completed
  EXPIRED           // Due date passed
  CANCELLED         // Cancelled by doctor
}

model AnalysisRequest {
  id                String           @id @default(auto()) @map("_id") @db.ObjectId
  doctorId          String           @db.ObjectId
  patientId         String           @db.ObjectId
  
  analysisType      AnalysisType
  testName          String           // Ex: "Numération Formule Sanguine", "Blood Pressure"
  description       String?          // Doctor notes about why this analysis is needed
  
  requestedAt       DateTime         @default(now())
  dueDate           DateTime?        // Deadline for patient to submit
  status            AnalysisRequestStatus @default(PENDING)
  
  // Optional document uploaded by doctor (e.g., lab request form)
  documentUrl       String?          // E.g., Azure Blob URL
  documentName      String?
  
  // Patient submission
  submittedAt       DateTime?
  submittedDocumentUrl String?       // URL to patient's uploaded result
  submittedDocumentName String?      // Original filename
  patientNotes      String?          // Notes from patient
  
  completedAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  // Relations
  doctor            User             @relation("DoctorAnalysisRequests", fields: [doctorId], references: [id], onDelete: Cascade)
  patient           Patient          @relation("PatientAnalysisRequests", fields: [patientId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([patientId])
  @@index([status])
  @@index([analysisType])
  @@index([requestedAt])
  @@map("analysis_requests")
}
