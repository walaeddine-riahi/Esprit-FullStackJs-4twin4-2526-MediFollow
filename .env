# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Next.js Base URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# API Base URL (if different from app)
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# Maximum file upload size (in MB)
MAX_FILE_SIZE=10

# Session timeout (in minutes)
SESSION_TIMEOUT=30

# =============================================================================
# VITAL THRESHOLDS (Default Values)
# =============================================================================
# These are default thresholds, can be overridden per patient

# Blood Pressure (mmHg)
DEFAULT_SYSTOLIC_MIN=90
DEFAULT_SYSTOLIC_MAX=140
DEFAULT_DIASTOLIC_MIN=60
DEFAULT_DIASTOLIC_MAX=90

# Heart Rate (bpm)
DEFAULT_HEART_RATE_MIN=60
DEFAULT_HEART_RATE_MAX=100

# Temperature (°C)
DEFAULT_TEMP_MIN=36.1
DEFAULT_TEMP_MAX=37.2

# Oxygen Saturation (%)
DEFAULT_SPO2_MIN=95
DEFAULT_SPO2_MAX=100

# Weight Change Alert Threshold (kg per week)
DEFAULT_WEIGHT_CHANGE_MAX=2

# =============================================================================
# ALERT CONFIGURATION
# =============================================================================
# Enable automatic alert generation
ENABLE_AUTO_ALERTS=true

# Alert check interval (in minutes)
ALERT_CHECK_INTERVAL=5

# Critical alert immediate notification
CRITICAL_ALERT_IMMEDIATE=true

# =============================================================================
# RATE LIMITING
# =============================================================================
# API Rate limit (requests per minute)
API_RATE_LIMIT=100

# Login attempts before lockout
MAX_LOGIN_ATTEMPTS=5

# Lockout duration (in minutes)
LOCKOUT_DURATION=15

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Allowed origins for CORS (comma-separated)
CORS_ORIGINS="http://localhost:3000,https://medifollow.health"

# =============================================================================
# CRON JOBS & BACKGROUND TASKS
# =============================================================================
# Enable background jobs
ENABLE_CRON_JOBS=true

# Blockchain sync interval (in minutes)
BLOCKCHAIN_SYNC_INTERVAL=10

# Notification batch processing interval (in minutes)
NOTIFICATION_BATCH_INTERVAL=2

# Session cleanup interval (in hours)
SESSION_CLEANUP_INTERVAL=24

# =============================================================================
# DEVELOPMENT & DEBUG
# =============================================================================
# Enable debug mode
DEBUG=false

# Log level (error, warn, info, debug)
LOG_LEVEL="info"

# Enable Prisma query logging
PRISMA_LOG_QUERIES=false

# =============================================================================
# DEMO MODE & SEEDING
# =============================================================================
# Enable demo mode with test data
DEMO_MODE=true

# Auto-seed database on first run
AUTO_SEED=true

# Demo admin credentials
DEMO_ADMIN_EMAIL="admin@medifollow.health"
DEMO_ADMIN_PASSWORD="Admin@123456"

# Demo doctor credentials
