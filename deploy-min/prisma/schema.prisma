// MediFollow - Post-Hospitalization Remote Monitoring Platform
// Prisma Schema for MongoDB
// Generated: March 2, 2026

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ============================================
// USER MANAGEMENT
// ============================================

model User {
  id                      String    @id @default(auto()) @map("_id") @db.ObjectId
  email                   String    @unique
  passwordHash            String
  firstName               String
  lastName                String
  role                    Role      @default(PATIENT)
  phoneNumber             String?
  blockchainAddress       String?   // Aptos wallet address (public) for blockchain access control
  blockchainPrivateKey    String?   // Aptos wallet private key (encrypted at rest)
  isActive                Boolean   @default(true)
  lastLogin               DateTime?
  resetPasswordToken      String?   // Token for password reset
  resetPasswordExpires    DateTime? // Expiration date for reset token
  faceDescriptor          Json?     // 128-dim float array for facial recognition login
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  // Relations
  patient       Patient?
  doctorProfile DoctorProfile?
  nurseProfile  NurseProfile?
  coordinatorProfile CoordinatorProfile?
  auditLogs     AuditLog[]
  alertsCreated Alert[]    @relation("AlertCreatedBy")
  alertsAcknowledged Alert[] @relation("AlertAcknowledgedBy")
  alertsResolved Alert[]    @relation("AlertResolvedBy")
  vitalRecordReviews VitalRecord[] @relation("VitalRecordReviews")  // Vitals reviewed by this doctor
  vitalRecordsEntered VitalRecord[] @relation("VitalRecordEnteredBy")  // Vitals entered by this user (nurse/patient)
  voiceTranscripts VoiceTranscript[] @relation("VoiceTranscripts")  // Voice entries by nurse
  questionnaireTemplates QuestionnaireTemplate[] @relation("QuestionnaireTemplates")  // Templates created by doctor
  analysisRequests AnalysisRequest[] @relation("AnalysisRequestDoctor")  // Analysis requests created by doctor
  sessions      Session[]

  @@map("users")
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
  NURSE
  COORDINATOR
  AUDITOR
}

// ============================================
// PATIENT MANAGEMENT
// ============================================

model Patient {
  id                    String    @id @default(auto()) @map("_id") @db.ObjectId
  userId                String    @unique @db.ObjectId
  medicalRecordNumber   String    @unique
  dateOfBirth           DateTime
  gender                Gender
  bloodType             BloodType?
  address               Address?
  emergencyContact      EmergencyContact?
  profileImage          String?   // Base64 or URL to profile image
  bio                   String?   // Patient personal bio
  dischargeDate         DateTime?
  diagnosis             String?
  medications           Medication[]
  medicalProfile        MedicalProfile?  // Medical profile from questionnaire
  vitalThresholds       VitalThresholds?
  isActive              Boolean   @default(true)
  questionnaireCompleted Boolean  @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  vitalRecords          VitalRecord[]
  symptoms              Symptom[]
  alerts                Alert[]
  questionnaires        Questionnaire[]
  questionnaireAssignments QuestionnaireAssignment[] @relation("QuestionnaireAssignments")
  medicalDocuments      MedicalDocument[]
  medicalAnalyses       MedicalAnalysis[]
  analysisRequests      AnalysisRequest[] @relation("AnalysisRequestPatient")

  @@map("patients")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum BloodType {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
}

// ============================================
// DOCTOR PROFILE
// ============================================

model DoctorProfile {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  userId          String       @unique @db.ObjectId
  specialty       String?
  bio             String?
  phone           String?
  location        String?
  profileImage    String?      // URL to profile image (Azure Blob Storage)
  experiences     Experience[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("doctor_profiles")
}

// ============================================
// NURSE PROFILE
// ============================================

model NurseProfile {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  userId          String       @unique @db.ObjectId
  department      String?
  shift           String?      // "morning" | "afternoon" | "night"
  phone           String?
  profileImage    String?      // URL to profile image (Azure Blob Storage)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("nurse_profiles")
}

// ============================================
// COORDINATOR PROFILE
// ============================================

model CoordinatorProfile {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  userId          String       @unique @db.ObjectId
  department      String?
  phone           String?
  profileImage    String?      // URL to profile image (Azure Blob Storage)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("coordinator_profiles")
}

type Experience {
  title         String
  institution   String
  startDate     DateTime
  endDate       DateTime?
  isCurrent     Boolean      @default(false)
  description   String?
}

// ============================================
// EMBEDDED TYPES FOR PATIENT
// ============================================

type Address {
  street      String
  city        String
  state       String
  postalCode  String
  country     String
}

type EmergencyContact {
  name         String
  relationship String
  phoneNumber  String
  email        String?
}

type Medication {
  name        String
  dosage      String
  frequency   String
  startDate   DateTime
  endDate     DateTime?
  notes       String?
}

type VitalThresholds {
  systolicBP          VitalRange
  diastolicBP         VitalRange
  heartRate           VitalRange
  temperature         VitalRange
  oxygenSaturation    VitalRange
  weight              VitalRange?
}

type VitalRange {
  min Float
  max Float
}

type MedicalProfile {
  hospital               String?
  department             String?
  specialty              String?
  height                 Float?          // in cm
  weight                 Float?          // in kg
  medicalBackground      MedicalBackground?
}

type MedicalBackground {
  diabetes               Boolean         @default(false)
  hypertension           Boolean         @default(false)
  cardiacDisease         Boolean         @default(false)
  asthmaOuBpco           Boolean         @default(false)
  cancer                 Boolean         @default(false)
  otherConditions        String?
}

// ============================================
// VITAL RECORDS
// ============================================

model VitalRecord {
  id                  String          @id @default(auto()) @map("_id") @db.ObjectId
  patientId           String          @db.ObjectId
  
  // Vital measurements
  systolicBP          Float?
  diastolicBP         Float?
  heartRate           Float?
  temperature         Float?
  oxygenSaturation    Float?
  weight              Float?
  
  // Additional data
  symptoms            Json?           // { symptomType: severity, ... }
  notes               String?
  triggeredRules      Json?           // Array of rules that triggered alerts
  
  // AI Analysis
  aiAnalysis          Json?           // AI-generated analysis and insights
  riskScore           Float?          // 0-100 AI-calculated risk score
  trendIndicator      String?         // "improving" | "stable" | "declining"
  aiRecommendations   String?         // AI-generated recommendations
  
  // Entry tracking (who entered this data)
  enteredBy           String?         @db.ObjectId  // User ID who entered this data
  enteredByRole       Role?                         // Role of person who entered (PATIENT/NURSE)
  
  // Status & Classification
  status              VitalStatus     @default(NORMAL)  // NORMAL | A_VERIFIER | CRITIQUE
  
  // Medical review by doctor
  reviewStatus        ReviewStatus    @default(PENDING) // PENDING | REVIEWED
  reviewedById        String?         @db.ObjectId
  reviewedAt          DateTime?
  reviewNotes         String?
  
  // Metadata
  recordedAt          DateTime        @default(now())
  blockchainTxHash    String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime?       @updatedAt

  // Relations
  patient             Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  reviewedBy          User?           @relation("VitalRecordReviews", fields: [reviewedById], references: [id])
  enteredByUser       User?           @relation("VitalRecordEnteredBy", fields: [enteredBy], references: [id])
  blockchainProof     BlockchainProof?
  alerts              Alert[]         // Alerts triggered by this vital
  voiceTranscripts    VoiceTranscript[] // Voice entries for this vital

  @@index([patientId])
  @@index([recordedAt])
  @@index([status])
  @@index([reviewStatus])
  @@map("vital_records")
}

enum VitalStatus {
  NORMAL              // Valeur normale
  A_VERIFIER          // Valeur anormale nécessitant vérification
  CRITIQUE            // Valeur critique nécessitant intervention urgente
}

enum ReviewStatus {
  PENDING             // En attente révision médecin
  REVIEWED            // Révisé par médecin
}

// ============================================
// SYMPTOMS
// ============================================

model Symptom {
  id           String         @id @default(auto()) @map("_id") @db.ObjectId
  patientId    String         @db.ObjectId
  symptomType  String
  severity     Severity
  description  String
  occurredAt   DateTime       @default(now())
  createdAt    DateTime       @default(now())

  // Relations
  patient      Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([occurredAt])
  @@map("symptoms")
}

enum Severity {
  MILD
  MODERATE
  SEVERE
}

// ============================================
// ALERTS
// ============================================

model Alert {
  id                  String          @id @default(auto()) @map("_id") @db.ObjectId
  patientId           String          @db.ObjectId
  
  // Alert source (what triggered it)
  vitalRecordId       String?         @db.ObjectId      // Lien vers VitalRecord si vitals triggered
  triggeredById       String?         @db.ObjectId      // User who triggered/created alert
  
  // Alert type & severity
  alertType           AlertType
  severity            AlertSeverity
  message             String
  data                Json?           // Extra data about alert
  
  // Status workflow: OPEN → ACKNOWLEDGED → RESOLVED → CLOSED
  status              AlertStatus     @default(OPEN)
  
  // Acknowledgment
  acknowledgedById    String?         @db.ObjectId
  acknowledgedAt      DateTime?
  
  // Resolution
  resolvedById        String?         @db.ObjectId
  resolvedAt          DateTime?
  resolution          String?         // Notes on how alert was resolved
  
  // Metadata
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  // Relations
  patient             Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  vitalRecord         VitalRecord?    @relation(fields: [vitalRecordId], references: [id], onDelete: SetNull)
  triggeredBy         User?           @relation("AlertCreatedBy", fields: [triggeredById], references: [id])
  acknowledgedBy      User?           @relation("AlertAcknowledgedBy", fields: [acknowledgedById], references: [id])
  resolvedBy          User?           @relation("AlertResolvedBy", fields: [resolvedById], references: [id])
  auditLogs           AuditLog[]

  @@index([patientId])
  @@index([vitalRecordId])
  @@index([status])
  @@index([severity])
  @@index([createdAt])
  @@map("alerts")
}

enum AlertType {
  VITAL
  SYMPTOM
  MEDICATION
  SYSTEM
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  CLOSED
}

// ============================================
// SERVICES
// ============================================

model Service {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  serviceName       String   @unique
  description       String?
  consultationFee   Float?
  averageDuration   Int?     // in minutes
  isActive          Boolean  @default(true)
  specializations   String[]
  patientIds        String[] @db.ObjectId // IDs of patients assigned to this service
  teamIds           String[] @db.ObjectId // IDs of doctors/nurses assigned to this service
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("services")
}

// ============================================
// QUESTIONNAIRES
// ============================================

model Questionnaire {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  patientId         String   @db.ObjectId
  questionnaireType String
  responses         Json
  overallScore      Float?
  completedAt       DateTime @default(now())
  createdAt         DateTime @default(now())

  // Relations
  patient           Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([completedAt])
  @@map("questionnaires")
}

// ============================================
// QUESTIONNAIRE TEMPLATES (Doctor-created)
// ============================================

model QuestionnaireTemplate {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  description     String?
  specialty       String?  // Medical specialty
  doctorId        String?  @db.ObjectId  // Doctor who created template
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  doctor          User?    @relation("QuestionnaireTemplates", fields: [doctorId], references: [id], onDelete: SetNull)
  questions       QuestionnaireQuestion[]
  assignments     QuestionnaireAssignment[]

  @@index([doctorId])
  @@index([specialty])
  @@index([isActive])
  @@map("questionnaire_templates")
}

// ============================================
// QUESTIONNAIRE QUESTIONS
// ============================================

model QuestionnaireQuestion {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  templateId        String   @db.ObjectId
  questionNumber    Int      // Order of question
  questionText      String
  questionType      String   // TEXT, TEXTAREA, NUMBER, RATING, YESNO, CHOICE, MULTIPLE_CHOICE, DATE, TIME, DATETIME
  description       String?
  required          Boolean  @default(false)
  options           Json?    // For CHOICE and MULTIPLE_CHOICE types (stored as JSON for flexibility)
  minValue          Int?     // For NUMBER type
  maxValue          Int?     // For NUMBER type
  minLength         Int?     // For TEXT types
  maxLength         Int?     // For TEXT types
  validationRegex   String?  // For custom validation
  placeholder       String?
  helpText          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  template          QuestionnaireTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  responses         QuestionnaireResponse[]

  @@index([templateId])
  @@index([questionNumber])
  @@map("questionnaire_questions")
}

// ============================================
// QUESTIONNAIRE ASSIGNMENTS
// ============================================

model QuestionnaireAssignment {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  templateId        String   @db.ObjectId
  patientId         String   @db.ObjectId
  status            String   @default("PENDING")  // PENDING, IN_PROGRESS, COMPLETED, OVERDUE
  dueDate           DateTime?
  assignedAt        DateTime @default(now())
  completedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  template          QuestionnaireTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  patient           Patient @relation("QuestionnaireAssignments", fields: [patientId], references: [id], onDelete: Cascade)
  responses         QuestionnaireResponse[]

  @@index([patientId, templateId])
  @@index([patientId])
  @@index([templateId])
  @@index([status])
  @@index([assignedAt])
  @@index([dueDate])
  @@map("questionnaire_assignments")
}

// ============================================
// QUESTIONNAIRE RESPONSES
// ============================================

model QuestionnaireResponse {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  assignmentId      String   @db.ObjectId
  questionId        String   @db.ObjectId
  answer            String?  // Stored as JSON string for flexibility with different types
  submittedAt       DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  assignment        QuestionnaireAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  question          QuestionnaireQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([assignmentId])
  @@index([questionId])
  @@index([submittedAt])
  @@map("questionnaire_responses")
}

// ============================================
// MEDICAL DOCUMENTS
// ============================================

model MedicalDocument {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  patientId       String         @db.ObjectId
  fileName        String
  originalName    String
  fileType        String
  fileSize        Int            // in bytes
  category        DocumentCategory
  description     String?
  azureBlobUrl    String
  azureContainerName String
  azureBlobName   String
  uploadedAt      DateTime       @default(now())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  patient         Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([uploadedAt])
  @@index([category])
  @@map("medical_documents")
}

enum DocumentCategory {
  ANALYSIS
  IMAGING
  PRESCRIPTION
  REPORT
  DISCHARGE_SUMMARY
  CONSULTATION
  OTHER
}

// ============================================
// MEDICAL ANALYSES
// ============================================

model MedicalAnalysis {
  id                String           @id @default(auto()) @map("_id") @db.ObjectId
  patientId         String           @db.ObjectId
  analysisType      AnalysisType
  testName          String           // Ex: "Numération Formule Sanguine", "Radiographie thorax"
  results           Json?            // Structured results (values, units, reference ranges)
  resultSummary     String?          // Text summary of results
  analysisDate      DateTime         @default(now())
  laboratory        String?          // Name of lab or medical center
  doctorNotes       String?
  status            AnalysisStatus   @default(PENDING)
  isAbnormal        Boolean          @default(false)
  documentIds       String[]         @db.ObjectId // Links to MedicalDocument for PDFs/images
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  // Relations
  patient           Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([analysisDate])
  @@index([analysisType])
  @@index([status])
  @@map("medical_analyses")
}

enum AnalysisType {
  BLOOD_TEST
  URINE_TEST
  IMAGING_XRAY
  IMAGING_CT_SCAN
  IMAGING_MRI
  IMAGING_ULTRASOUND
  IMAGING_PET_SCAN
  ECG
  ECHOCARDIOGRAPHY
  SPIROMETRY
  BIOPSY
  CULTURE
  OTHER
}

enum AnalysisStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ============================================
// AUDIT LOGS
// ============================================

model AuditLog {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  userId            String   @db.ObjectId
  action            String
  entityType        String
  entityId          String?  @db.ObjectId
  changes           Json?
  ipAddress         String?
  userAgent         String?
  blockchainTxHash  String?
  timestamp         DateTime @default(now())

  // Relations
  user              User     @relation(fields: [userId], references: [id])
  alert             Alert?   @relation(fields: [entityId], references: [id])
  blockchainProof   BlockchainProof?

  @@index([userId])
  @@index([entityType])
  @@index([timestamp])
  @@map("audit_logs")
}

// ============================================
// BLOCKCHAIN PROOF
// ============================================

model BlockchainProof {
  id                String       @id @default(auto()) @map("_id") @db.ObjectId
  dataHash          String
  txHash            String       @unique
  blockchainNetwork String       @default("aptos-testnet")
  blockNumber       Int?
  timestamp         DateTime     @default(now())
  status            BlockchainStatus @default(PENDING)
  
  // Relations (one-to-one)
  vitalRecordId     String?      @unique @db.ObjectId
  vitalRecord       VitalRecord? @relation(fields: [vitalRecordId], references: [id])
  
  auditLogId        String?      @unique @db.ObjectId
  auditLog          AuditLog?    @relation(fields: [auditLogId], references: [id])

  @@index([timestamp])
  @@map("blockchain_proofs")
}

enum BlockchainStatus {
  PENDING
  CONFIRMED
  FAILED
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id            String             @id @default(auto()) @map("_id") @db.ObjectId
  recipientId   String             @db.ObjectId
  type          NotificationType
  title         String
  message       String
  data          Json?
  isRead        Boolean            @default(false)
  readAt        DateTime?
  sentVia       NotificationChannel[]
  createdAt     DateTime           @default(now())

  @@index([recipientId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

enum NotificationType {
  ALERT
  REMINDER
  SYSTEM
  MESSAGE
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  PUSH
}

// ============================================
// SESSIONS (for JWT refresh tokens)
// ============================================

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  ipAddress    String?
  userAgent    String?

  // Relations
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// ============================================
// MEDICAL FORMS (Doctor-defined checkup forms)
// ============================================

model MedicalForm {
  id          String             @id @default(auto()) @map("_id") @db.ObjectId
  doctorId    String             @db.ObjectId
  title       String
  description String?
  category    String?            // e.g. "Cardiologie", "Diabète", "Suivi post-op"
  fields      MedicalFormField[]
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  // Relations
  checkups    PatientCheckup[]

  @@index([doctorId])
  @@index([isActive])
  @@map("medical_forms")
}

type MedicalFormField {
  id           String   // client-generated UUID
  label        String
  fieldType    String   // "text" | "number" | "textarea" | "select" | "checkbox" | "date"
  required     Boolean  @default(false)
  placeholder  String?
  options      String[] // for "select" type
  unit         String?  // for "number" e.g. "kg", "bpm"
  order        Int      @default(0)
}

// ============================================
// PATIENT CHECKUPS (form submissions)
// ============================================

model PatientCheckup {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  formId     String   @db.ObjectId
  patientId  String   @db.ObjectId
  doctorId   String   @db.ObjectId
  answers    Json     // { fieldId: value, ... }
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  form       MedicalForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
  @@index([patientId])
  @@index([doctorId])
  @@index([createdAt])
  @@map("patient_checkups")
}

// ============================================
// ACCESS GRANTS (Patient → Doctor blockchain permissions)
// ============================================

model AccessGrant {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  patientId       String    @db.ObjectId  // User.id of patient
  doctorId        String    @db.ObjectId  // User.id of doctor
  durationDays    Int       @default(365)
  grantedAt       DateTime  @default(now())
  expiresAt       DateTime?
  revokedAt       DateTime?
  isActive        Boolean   @default(true)
  txHashGrant     String?   // Blockchain tx hash for grant
  txHashRevoke    String?   // Blockchain tx hash for revoke

  @@unique([patientId, doctorId])
  @@index([patientId])
  @@index([doctorId])
  @@index([isActive])
  @@map("access_grants")
}

// ============================================
// NURSE ASSIGNMENTS (Patient → Nurse)
// ============================================

model NurseAssignment {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  nurseId     String   @db.ObjectId
  patientId   String   @db.ObjectId
  assignedAt  DateTime @default(now())
  assignedBy  String?  @db.ObjectId  // Admin/Doctor who assigned
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([nurseId, patientId])
  @@index([nurseId])
  @@index([patientId])
  @@index([isActive])
  @@map("nurse_assignments")
}

// ============================================
// PATIENT COMMUNICATION (Coordinator → Patient)
// ============================================

model PatientCommunication {
  id              String              @id @default(auto()) @map("_id") @db.ObjectId
  patientId       String              @db.ObjectId
  coordinatorId   String              @db.ObjectId
  type            CommunicationType
  subject         String?
  message         String
  sentAt          DateTime            @default(now())
  readAt          DateTime?
  isRead          Boolean             @default(false)
  
  @@index([patientId])
  @@index([coordinatorId])
  @@index([sentAt])
  @@map("patient_communications")
}

enum CommunicationType {
  REMINDER
  GUIDANCE
  FOLLOW_UP
}

// ============================================
// COMPLIANCE TRACKING
// ============================================

model ComplianceRecord {
  id                      String            @id @default(auto()) @map("_id") @db.ObjectId
  patientId               String            @db.ObjectId
  date                    DateTime
  vitalsSubmitted         Boolean           @default(false)
  vitalsCount             Int               @default(0)
  symptomsReported        Boolean           @default(false)
  symptomsCount           Int               @default(0)
  questionnairesCompleted Boolean           @default(false)
  questionnairesCount     Int               @default(0)
  status                  ComplianceStatus
  lastCheckedAt           DateTime          @default(now())
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  
  @@unique([patientId, date])
  @@index([patientId])
  @@index([date])
  @@index([status])
  @@map("compliance_records")
}

enum ComplianceStatus {
  COMPLIANT
  PARTIAL
  NON_COMPLIANT
}

// ============================================
// VOICE TRANSCRIPTS
// ============================================

model VoiceTranscript {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  vitalRecordId   String       @db.ObjectId
  nurseId         String       @db.ObjectId
  transcript      String       // Raw voice transcription
  parsedData      Json         // AI-extracted vital signs
  language        String       // "fr" | "en"
  confidence      Float?       // 0-1 Speech recognition confidence
  createdAt       DateTime     @default(now())
  
  vitalRecord     VitalRecord  @relation(fields: [vitalRecordId], references: [id], onDelete: Cascade)
  nurse           User         @relation("VoiceTranscripts", fields: [nurseId], references: [id])
  
  @@index([vitalRecordId])
  @@index([nurseId])
  @@index([createdAt])
  @@map("voice_transcripts")
}

// ============================================
// AI ANALYSIS CACHE
// ============================================

model AIAnalysisCache {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  nurseId         String   @db.ObjectId
  analysisType    String   // "cohort_insights" | "risk_summary" | "predictions"
  data            Json     // Cached AI response
  expiresAt       DateTime
  createdAt       DateTime @default(now())
  
  @@index([nurseId, analysisType])
  @@index([expiresAt])
  @@map("ai_analysis_cache")
}

// ============================================
// ANALYSIS REQUESTS
// ============================================

model AnalysisRequest {
  id                      String   @id @default(auto()) @map("_id") @db.ObjectId
  doctorId                String   @db.ObjectId
  patientId               String   @db.ObjectId
  analysisType            String   // "general", "cardio", "labs", etc.
  testName                String
  status                  String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, REJECTED
  description             String?
  dueDate                 DateTime?
  documentUrl             String?
  documentName            String?
  submittedAt             DateTime?
  submittedDocumentUrl    String?
  submittedDocumentName   String?
  patientNotes            String?
  results                 Json?
  requestedAt             DateTime @default(now())
  completedAt             DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  
  doctor                  User     @relation("AnalysisRequestDoctor", fields: [doctorId], references: [id], onDelete: Cascade)
  patient                 Patient  @relation("AnalysisRequestPatient", fields: [patientId], references: [id], onDelete: Cascade)
  
  @@index([doctorId])
  @@index([patientId])
  @@index([status])
  @@index([requestedAt])
  @@map("analysis_requests")
}
