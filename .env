# =============================================================================
# DATABASE CONFIGURATION (MongoDB + Prisma)
# =============================================================================
# MongoDB Atlas or local MongoDB connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/medifollow
DATABASE_URL="mongodb+srv://walaeddine1207_db_user:2SuGPwjYdeRBqQ2c@cluster0.8j1bosg.mongodb.net/medifollow?retryWrites=true&w=majority"

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# JWT Secret for access tokens (min 32 characters)
JWT_SECRET="your-super-secret-jwt-key-min-32-chars-long-change-in-production"

# JWT Refresh Token Secret
JWT_REFRESH_SECRET="your-refresh-token-secret-key-change-in-production"

# Access Token Expiry (default: 15 minutes)
JWT_ACCESS_EXPIRY="15m"

# Refresh Token Expiry (default: 7 days)
JWT_REFRESH_EXPIRY="7d"

# Password Hash Rounds (bcrypt)
BCRYPT_ROUNDS=12

# AES-256-GCM Encryption Key for blockchain private keys (64-char hex = 32 bytes)
# Generate new key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Back this up securely — losing it makes encrypted wallets unrecoverable
WALLET_ENCRYPTION_KEY="e628231601f073c383eea3e5b180d4abd0d7f367ab4643622889a77fda155711"

# =============================================================================
# BLOCKCHAIN CONFIGURATION (Aptos)
# =============================================================================
# Enable/Disable Blockchain (set to "false" to disable for development)
BLOCKCHAIN_ENABLED="true"

# Aptos Network (testnet, mainnet, devnet)
BLOCKCHAIN_NETWORK="aptos-testnet"

# Aptos RPC Endpoint
APTOS_NODE_URL="https://fullnode.testnet.aptoslabs.com/v1"

# Aptos Faucet (for testnet only)
APTOS_FAUCET_URL="https://faucet.testnet.aptoslabs.com"

# Aptos Private Key (for signing transactions - KEEP SECRET)
APTOS_PRIVATE_KEY="0xd8c98320e8fb3694e752f74d8a71ffa72b1d50394d08c0e932592c5d97416b4e"

# Aptos Account Address
APTOS_ACCOUNT_ADDRESS="0x43f2e7420983c87eb131d936c18237d68f19952aeac6fd49778c7507062347f1"

# Smart Contract Module Address
APTOS_CONTRACT_MODULE="0x43f2e7420983c87eb131d936c18237d68f19952aeac6fd49778c7507062347f1::access_control"

# =============================================================================
# NOTIFICATION SERVICES
# =============================================================================

# --- Twilio SMS Configuration (DEPRECATED - USE REAL CONFIG BELOW) ---
# TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# TWILIO_AUTH_TOKEN="your_twilio_auth_token"
# TWILIO_PHONE_NUMBER="+1234567890"

# --- SendGrid Email Configuration ---
SENDGRID_API_KEY="SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
SENDGRID_FROM_EMAIL="noreply@medifollow.health"
SENDGRID_FROM_NAME="MediFollow Platform"

# --- Alternative: Nodemailer SMTP Configuration ---
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# --- Firebase Cloud Messaging (Push Notifications) ---
FIREBASE_PROJECT_ID="medifollow-prod"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@medifollow-prod.iam.gserviceaccount.com"

# =============================================================================
# MONITORING & ERROR TRACKING
# =============================================================================
# Sentry DSN for error tracking
SENTRY_DSN="https://xxxxxxxxxxxxx@o1234567.ingest.sentry.io/1234567"
SENTRY_ORG="medifollow"
SENTRY_PROJECT="medifollow-platform"

# Sentry Auth Token (for CI/CD)
SENTRY_AUTH_TOKEN="your_sentry_auth_token"

# Environment (development, staging, production)
NODE_ENV="development"

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Next.js Base URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# API Base URL (if different from app)
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# Maximum file upload size (in MB)
MAX_FILE_SIZE=10

# Session timeout (in minutes)
SESSION_TIMEOUT=30

# =============================================================================
# VITAL THRESHOLDS (Default Values)
# =============================================================================
# These are default thresholds, can be overridden per patient

# Blood Pressure (mmHg)
DEFAULT_SYSTOLIC_MIN=90
DEFAULT_SYSTOLIC_MAX=140
DEFAULT_DIASTOLIC_MIN=60
DEFAULT_DIASTOLIC_MAX=90

# Heart Rate (bpm)
DEFAULT_HEART_RATE_MIN=60
DEFAULT_HEART_RATE_MAX=100

# Temperature (°C)
DEFAULT_TEMP_MIN=36.1
DEFAULT_TEMP_MAX=37.2

# Oxygen Saturation (%)
DEFAULT_SPO2_MIN=95
DEFAULT_SPO2_MAX=100

# Weight Change Alert Threshold (kg per week)
DEFAULT_WEIGHT_CHANGE_MAX=2

# =============================================================================
# ALERT CONFIGURATION
# =============================================================================
# Enable automatic alert generation
ENABLE_AUTO_ALERTS=true

# Alert check interval (in minutes)
ALERT_CHECK_INTERVAL=5

# Critical alert immediate notification
CRITICAL_ALERT_IMMEDIATE=true

# =============================================================================
# RATE LIMITING
# =============================================================================
# API Rate limit (requests per minute)
API_RATE_LIMIT=100

# Login attempts before lockout
MAX_LOGIN_ATTEMPTS=5

# Lockout duration (in minutes)
LOCKOUT_DURATION=15

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Allowed origins for CORS (comma-separated)
CORS_ORIGINS="http://localhost:3000,https://medifollow.health"

# =============================================================================
# CRON JOBS & BACKGROUND TASKS
# =============================================================================
# Enable background jobs
ENABLE_CRON_JOBS=true

# Blockchain sync interval (in minutes)
BLOCKCHAIN_SYNC_INTERVAL=10

# Notification batch processing interval (in minutes)
NOTIFICATION_BATCH_INTERVAL=2

# Session cleanup interval (in hours)
SESSION_CLEANUP_INTERVAL=24

# =============================================================================
# DEVELOPMENT & DEBUG
# =============================================================================
# Enable debug mode
DEBUG=false

# Log level (error, warn, info, debug)
LOG_LEVEL="info"

# Enable Prisma query logging
PRISMA_LOG_QUERIES=false

# =============================================================================
# DEMO MODE & SEEDING
# =============================================================================
# Enable demo mode with test data
DEMO_MODE=true

# Auto-seed database on first run
AUTO_SEED=true

# Demo admin credentials
DEMO_ADMIN_EMAIL="admin@medifollow.health"
DEMO_ADMIN_PASSWORD="Admin@123456"

# Demo doctor credentials
DEMO_DOCTOR_EMAIL="doctor@medifollow.health"
DEMO_DOCTOR_PASSWORD="Doctor@123456"

# Demo patient credentials
DEMO_PATIENT_EMAIL="patient@medifollow.health"
DEMO_PATIENT_PASSWORD="Patient@123456"

